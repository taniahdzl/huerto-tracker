rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.rol == 'admin';
    }

    // Deny-by-default: cualquier colección no listada explícitamente
    // abajo queda bloqueada, tanto en lectura como en escritura.
    match /{document=**} {
      allow read, write: if false;
    }

    // ── Catálogos y Camas: todos leen/crean/actualizan, solo admin elimina ──
    match /catalogo_semillas/{plantaId} {
      allow read, create, update: if request.auth != null;
      allow delete: if request.auth != null && isAdmin();
    }

    match /catalogo_quimicos/{quimicoId} {
      allow read, create, update: if request.auth != null;
      allow delete: if request.auth != null && isAdmin();
    }

    match /camas_cosecha/{camaId} {
      allow read, create, update: if request.auth != null;
      allow delete: if request.auth != null && isAdmin();
    }

    // registro_actividad: sin cambios, fuera de la matriz RBAC de esta
    // fase — sigue siendo log de auditoría append-only (ver _logActividad
    // en db.js/chores.js/usuarios.js).
    match /registro_actividad/{logId} {
      allow read:          if request.auth != null;
      allow create:        if request.auth != null;
      allow update, delete: if false;
    }

    // ── Inventario, Tareas, Asistencias: todos leen, solo admin escribe ──
    match /tareas/{tareaId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && isAdmin();
    }

    // asistencias es la fuente única de horas (Fase 13.2) — automáticas
    // (Regla del Sábado), ad-hoc y ajustes de migración conviven aquí,
    // todas con origen/motivo/autorizadoPor. Append-only: ni siquiera un
    // admin puede update/delete, igual que registro_actividad — una
    // corrección se hace con un nuevo registro negativo, nunca editando
    // uno existente, para que el historial sea confiable para un reporte
    // a la universidad.
    match /asistencias/{asistenciaId} {
      allow read:           if request.auth != null;
      allow create:         if request.auth != null && isAdmin();
      allow update, delete: if false;
    }

    match /inventario_general/{itemId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && isAdmin();
    }

    // historial_cultivo: append-only, mismo criterio que asistencias —
    // cualquiera puede cerrar un cultivo (create), nadie edita/borra un
    // cierre ya escrito. Confirmado por grep (ver PASO B): ningún código
    // existente hace update/delete sobre esta colección.
    match /historial_cultivo/{registroId} {
      allow read:           if request.auth != null;
      allow create:         if request.auth != null;
      allow update, delete: if false;
    }

    // bitacora_sesiones: append-only, sin restricción de una-por-fecha —
    // corregir una entrada mal escrita es crear una nueva, no editar la
    // vieja, mismo criterio que el resto del historial de auditoría.
    match /bitacora_sesiones/{sesionId} {
      allow read:           if request.auth != null;
      allow create:         if request.auth != null;
      allow update, delete: if false;
    }

    // ── Usuarios ──────────────────────────────────────────────────
    // Un admin nunca se autoasigna — se promueve manualmente (Fase 13).
    // create: solo el propio uid, y solo con rol en la whitelist —
    // 'admin' es explícitamente imposible en la escritura inicial, sin
    // importar qué mande el cliente. horasTotales debe nacer en 0 (no
    // solo por convención de registrarUsuario(), sino forzado aquí).
    // update: un admin puede escribir cualquier cosa en cualquier perfil
    // (incluida la promoción a admin, y ajustarHoras()). Un no-admin
    // editando su propio perfil (futura vista de Perfil/Ajustes) puede
    // cambiar su rol solo entre estudiante/externo, y nunca sus propias
    // horasTotales — eso sigue siendo exclusivo de ajustarHoras() por
    // un admin.
    match /usuarios/{userId} {
      allow read: if request.auth != null;

      allow create: if request.auth != null
                    && request.auth.uid == userId
                    && request.resource.data.rol in ['estudiante', 'externo']
                    && request.resource.data.horasTotales == 0;

      allow update: if request.auth != null && (
        isAdmin() ||
        (
          request.auth.uid == userId &&
          request.resource.data.rol in ['estudiante', 'externo'] &&
          request.resource.data.horasTotales == resource.data.horasTotales
        )
      );

      allow delete: if request.auth != null && isAdmin();
    }
  }
}
